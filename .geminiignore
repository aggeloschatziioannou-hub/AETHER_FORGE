.firebase/

# --- AI-specific: ignored by agents but tracked by git ---

# Lockfiles — no agent needs to read these, 84KB token trap
aether-forge-app/package-lock.json
.opencode/package-lock.json

# AI-generated analytics bundles — 48KB of regenerated noise
memory-vault/analytics/

# Empty or staged directories
memory-vault/snapshots/

# Stale backup config
opencode.json.tui-migration.bak
