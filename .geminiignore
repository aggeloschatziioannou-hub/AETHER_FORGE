# Environment & secrets
.env
.env.*
!.env.example
*.key
*.pem
*.crt

# Logs
*.log
firebase-debug.log

# OS metadata
.DS_Store
Thumbs.db

# Editor temp files
*.swp
*.swo
*~

# TypeScript build info
*.tsbuildinfo

